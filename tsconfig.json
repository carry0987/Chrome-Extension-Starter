{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "importHelpers": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "react": ["./node_modules/preact/compat/"],
      "react/jsx-runtime": ["./node_modules/preact/jsx-runtime"],
      "react-dom": ["./node_modules/preact/compat/"],
      "react-dom/*": ["./node_modules/preact/compat/*"]
    },
    "types": ["chrome", "@rsbuild/core/types"]
  },
  "include": ["src/**/*", "__tests__/**/*", "rsbuild.config.ts", "vitest.config.ts", "public/manifest.json"],
  "exclude": ["node_modules", "dist", "**/__snapshots__/**/*"]
}
