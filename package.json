{
  "name": "chrome-extension-starter",
  "version": "1.4.1",
  "description": "Chrome Extension Starter, using TypeScript, Preact, TailwindCSS, Vitest and RSBuild.",
  "type": "module",
  "scripts": {
    "build": "rsbuild build --mode=development",
    "build:prod": "rsbuild build --mode=production",
    "build:watch": "rsbuild build --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carry0987/Chrome-Extension-Starter.git"
  },
  "keywords": [
    "chrome-extension",
    "typescript",
    "preact",
    "tailwindcss",
    "tailgrids",
    "vitest",
    "rsbuild"
  ],
  "author": "carry0987",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carry0987/Chrome-Extension-Starter/issues"
  },
  "homepage": "https://github.com/carry0987/Chrome-Extension-Starter#readme",
  "dependencies": {
    "preact": "^10.29.0",
    "tailgrids": "^2.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@carry0987/utils": "^3.10.3",
    "@rsbuild/core": "^1.7.4",
    "@rsbuild/plugin-preact": "^1.7.2",
    "@rsbuild/plugin-type-check": "^1.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
